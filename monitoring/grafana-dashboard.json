{
  "dashboard": {
    "title": "LLM Evaluation Framework",
    "panels": [
      {
        "title": "HTTP Request Rate",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "HTTP Request Duration (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Model API Latency by Provider",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(model_request_duration_seconds_bucket[5m])) by (provider)"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Evaluation Latency by Metric",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(evaluation_duration_seconds_bucket[5m])) by (metric_name)"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Model Request Success Rate",
        "targets": [
          {
            "expr": "rate(model_requests_total{status=\"success\"}[5m]) / rate(model_requests_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Cache Hit Rate",
        "targets": [
          {
            "expr": "rate(cache_operations_total{operation=\"hit\"}[5m]) / rate(cache_operations_total{operation=~\"hit|miss\"}[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Active Experiments",
        "targets": [
          {
            "expr": "active_experiments"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Error Rate by Endpoint",
        "targets": [
          {
            "expr": "rate(http_requests_total{status_code=~\"5..\"}[5m]) by (endpoint)"
          }
        ],
        "type": "graph"
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
